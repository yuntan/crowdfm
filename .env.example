# Default: API-key-free local preview.
CROWDFM_PROVIDER=mock
CROWDFM_MOCK_DELAY_MS=450

# Real OpenAI production. Never commit the actual key.
# CROWDFM_PROVIDER=openai
# OPENAI_API_KEY=
# CROWDFM_CATALOG_PATH=data/suno-tracks.json

# Optional local storage override. Keep it outside Next.js watched source files.
# CROWDFM_DATABASE_PATH=.crowdfm/crowdfm.sqlite
